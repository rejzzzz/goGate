# Gateway Configuration
GATEWAY_PORT=8080
GATEWAY_ADMIN_PORT=9090
GATEWAY_READ_TIMEOUT=10s
GATEWAY_WRITE_TIMEOUT=10s
GATEWAY_IDLE_TIMEOUT=60s
GATEWAY_SHUTDOWN_TIMEOUT=30s

# Redis Configuration
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=50
REDIS_MIN_IDLE_CONNS=10
REDIS_MAX_RETRIES=3

# Logging Configuration
GATEWAY_LOG_LEVEL=info
GATEWAY_LOG_FORMAT=json

# Metrics Configuration
GATEWAY_METRICS_ENABLED=true
GATEWAY_METRICS_PATH=/metrics

# Admin Configuration
GATEWAY_ADMIN_TOKEN=changeme

# Rate Limiting Configuration
GATEWAY_GLOBAL_RATE_LIMIT_REQUESTS_PER_SECOND=1000
GATEWAY_GLOBAL_RATE_LIMIT_BURST=1200
GATEWAY_RATE_LIMIT_BYPASS_HEADER=X-Stress-Test-Token
GATEWAY_RATE_LIMIT_BYPASS_TOKEN=your-super-secret-token
