# Server Configuration
SERVER_PORT=8080
SERVER_ADMIN_PORT=9090
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=10s
SERVER_IDLE_TIMEOUT=60s
SERVER_SHUTDOWN_TIMEOUT=30s

# Redis Configuration
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=50
REDIS_MIN_IDLE_CONNS=10
REDIS_MAX_RETRIES=3

# Logging Configuration
LOGGING_LEVEL=info
LOGGING_FORMAT=json

# Metrics Configuration
METRICS_ENABLED=true
METRICS_PATH=/metrics

# Admin Configuration
# GATEWAY_ADMIN_TOKEN=changeme

# Rate Limiting Configuration
GLOBAL_RATE_LIMIT_REQUESTS_PER_SECOND=1000
GLOBAL_RATE_LIMIT_BURST=1200
RATE_LIMIT_BYPASS_HEADER=X-Stress-Test-Token
RATE_LIMIT_BYPASS_TOKEN=your-super-secret-token

# Auth Configuration
AUTH_ENABLED=true
AUTH_API_KEYS="sk_test_1234567890,sk_live_0987654321"

# Stress Test Configuration (used by scripts/breaking_point)
STRESS_TEST_BYPASS_HEADER=X-Stress-Test-Token
STRESS_TEST_BYPASS_TOKEN=your-super-secret-token
TEST_API_KEY=sk_test_1234567890
TARGET_URL=https://api.gogate.rejwanul.dev/api/v1/users

# Domain Configurations (used by deploy/Caddyfile)
GATEWAY_API_DOMAIN=api.gogate.rejwanul.dev
GATEWAY_ADMIN_DOMAIN=gogate.rejwanul.dev

